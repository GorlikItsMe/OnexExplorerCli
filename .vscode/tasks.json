{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build OnexExplorerCli",
      "type": "shell",
      "command": "cmake --build build --target OnexExplorerCli",
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Configure CMake"
      ]
    },
    {
      "label": "Build Tests",
      "type": "shell",
      "command": "cmake --build build --target OnexExplorerTests",
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Configure CMake"
      ]
    },
    {
      "label": "Configure CMake",
      "type": "shell",
      "command":
          "cmake -S all -B build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_TYPE=Debug",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
